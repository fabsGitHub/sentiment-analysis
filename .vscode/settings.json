{
    // --- Python & Environment Settings ---
    "python.defaultInterpreterPath": "${workspaceFolder}/venv/bin/python",
    "python.analysis.typeCheckingMode": "basic",
    "python.analysis.autoImportCompletions": true,

    // --- Code Formatting & Linting (Using Ruff) ---
    "[python]": {
        "editor.defaultFormatter": "charliermarsh.ruff",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.fixAll.ruff": "explicit",
            "source.organizeImports.ruff": "explicit"
        }
    },
    "ruff.lint.run": "onSave",

    // --- Jupyter Notebook Settings ---
    "notebook.formatOnSave.enabled": true,
    "notebook.insertFinalNewline": true,
    "notebook.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },

    // --- General Editor Settings (Readability & Reproducibility) ---
    "editor.renderWhitespace": "selection",
    "editor.rulers": [88], // Standard line length guide for clean code
    "files.insertFinalNewline": true,
    "files.trimTrailingWhitespace": true,
    
    // --- File Exclusions (Keeps your sidebar clean) ---
    "files.exclude": {
        "**/.git": true,
        "**/.DS_Store": true,
        "**/__pycache__": true,
        "**/.pytest_cache": true,
        "**/.ruff_cache": true,
        "**/venv": false // Keep false so you can verify your virtual environment exists
    }
}